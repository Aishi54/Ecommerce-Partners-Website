---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const projects = [
  {
    title: "Shopify Store for Fashion Brand",
    subtitle: "Full Store Development + CRO Optimization",
    image: "/images/p1.png",
    logomark: "/images/logos/luckycharm.png",
    logotext: "",
    column: 1,
    category: "WEB DESIGN"
  },
  {
    title: "Amazon Storefront for Beauty Brand",
    subtitle: "Brand Registry Setup + A+ Content",
    image: "/images/p2.png",
    logomark: "/images/logos/pollinate.png",
    logotext: "",
    column: 2,
    category: "BRANDING"
  },
  {
    title: "WooCommerce Store for Electronics Brand",
    subtitle: "Custom Theme + Payment Integration",
    image: "/images/p3.png",
    logomark: "/images/logos/launchsimple.png",
    logotext: "",
    column: 1,
    category: "MOBILE APPS"
  },
  {
    title: "Multi-Channel Setup for Lifestyle Brand",
    subtitle: "Shopify + Amazon + Facebook Shop Integration",
    image: "/images/p4.png",
    logomark: "/images/logos/lightbox.png",
    logotext: "",
    column: 2,
    category: "WEB DESIGN"
  },
];

const filters = ["ALL PROJECTS", "BRANDING", "WEB DESIGN", "MOBILE APPS"];
---

<Layout title="Our Work - Ecommerce Partners">
  <Header />

  <main>
    <!-- Hero Section -->
    <section class="work-hero">
      <div class="hero-bg-text">
        <div class="marquee-track">
          <div class="marquee-item">
            OUR WORK — SUCCESS STORIES — PORTFOLIO — ECOMMERCE —
          </div>
          <div class="marquee-item" aria-hidden="true">
            OUR WORK — SUCCESS STORIES — PORTFOLIO — ECOMMERCE —
          </div>
        </div>
      </div>
      <div class="container hero-content">
        <h1 class="hero-title">
          PREMIUM <br /><span class="highlight">WORK</span>
        </h1>
        <p class="hero-subtitle">• CREATIVE AS IT SHOULD BE</p>
      </div>
    </section>

    <!-- Filter Bar -->
    <section class="filter-bar">
      <div class="container filter-container">
        <div class="filters">
          {
            filters.map((filter, index) => (
              <button class={`filter-btn ${index === 0 ? "active" : ""}`}>
                {filter}
              </button>
            ))
          }
        </div>
        <div class="results-count">Showing 6 Results</div>
      </div>
    </section>

    <!-- Projects Gallery -->
    <section class="gallery-section">
      <div class="container gallery-grid">
        <div class="column">
          {
            projects
              .filter((p) => p.column === 1)
              .map((project) => (
                <div class="project-card" data-category={project.category}>
                  <div class="image-wrapper">
                    <img
                      src={project.image}
                      alt={project.title}
                      class="project-img"
                    />
                    <div class="logo-overlay">
                      <img src={project.logomark} alt="" class="logomark" />
                      <img src={project.logotext} alt="" class="logotext" />
                    </div>
                  </div>
                  <div class="project-info">
                    <h3>{project.title}</h3>
                    <p>{project.subtitle}</p>
                  </div>
                </div>
              ))
          }
        </div>
        <div class="column offset">
          {
            projects
              .filter((p) => p.column === 2)
              .map((project) => (
                <div class="project-card" data-category={project.category}>
                  <div class="image-wrapper">
                    <img
                      src={project.image}
                      alt={project.title}
                      class="project-img"
                    />
                    <div class="logo-overlay">
                      <img src={project.logomark} alt="" class="logomark" />
                      <img src={project.logotext} alt="" class="logotext" />
                    </div>
                  </div>
                  <div class="project-info">
                    <h3>{project.title}</h3>
                    <p>{project.subtitle}</p>
                  </div>
                </div>
              ))
          }
        </div>
      </div>
    </section>

    <script>
      const filterButtons = document.querySelectorAll('.filter-btn');
      const projectCards = document.querySelectorAll('.project-card');

      filterButtons.forEach(button => {
        button.addEventListener('click', () => {
          // Update active button state
          filterButtons.forEach(btn => btn.classList.remove('active'));
          button.classList.add('active');

          const filterValue = button.textContent?.trim().toUpperCase();

          projectCards.forEach((card: any) => {
            const cardCategory = card.getAttribute('data-category');
            
            if (filterValue === 'ALL PROJECTS' || filterValue === cardCategory) {
              card.style.display = 'flex';
              // Trigger a small animation
              card.style.opacity = '0';
              setTimeout(() => {
                card.style.opacity = '1';
                card.style.transform = 'translateY(0)';
              }, 50);
            } else {
              card.style.display = 'none';
            }
          });
        });
      });
    </script>

    <!-- CTA Section -->
    <section class="cta-section">
      <div class="cta-card">
        <div class="cta-bg-wrapper">
          <div class="cta-bg-text">START</div>
        </div>
        <div class="container cta-content">
          <h2 class="cta-title">READY TO START <br /> A <span class="white-text">PROJECT?</span></h2>
          <a href="/contact" class="cta-btn">
            <span>GET IN TOUCH —&gt;</span>
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  main {
    background-color: var(--primary);
  }

  /* Hero Section */
  .work-hero {
    padding: 160px 0 80px;
    position: relative;
    overflow: hidden;
    color: white;
  }

  .hero-bg-text {
    position: absolute;
    top: 50%;
    left: 0;
    width: 100%;
    transform: translateY(-50%);
    pointer-events: none;
    opacity: 0.1;
    z-index: 0;
    white-space: nowrap;
    overflow: hidden;
  }

  .marquee-track {
    display: flex;
    width: max-content;
    animation: scroll-right 50s linear infinite;
  }

  .marquee-item {
    font-family: "Anton SC", sans-serif;
    font-size: 250px;
    line-height: 1;
    color: #fff;
    padding-right: 100px;
    text-transform: uppercase;
  }

  @keyframes scroll-right {
    0% {
      transform: translateX(-50%);
    }
    100% {
      transform: translateX(0);
    }
  }

  .hero-content {
    position: relative;
    z-index: 1;
  }

  .hero-title {
    font-size: 80px;
    font-weight: 900;
    line-height: 1;
    letter-spacing: -4px;
    text-transform: uppercase;
    margin-bottom: 20px;
  }

  .highlight {
    color: #ff5c26;
  }

  .hero-subtitle {
    font-size: 18px;
    font-weight: 700;
    color: #ccff00;
    letter-spacing: 1px;
  }

  /* Filter Bar */
  .filter-bar {
    background-color: white;
    padding: 40px 0;
    border-bottom: 1px solid #e5e7eb;
  }

  .filter-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .filters {
    display: flex;
    gap: 48px;
  }

  .filter-btn {
    font-size: 14px;
    font-weight: 700;
    color: #9ca3af;
    background: none;
    border: none;
    cursor: pointer;
    padding-bottom: 8px;
    white-space: nowrap;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    position: relative;
    transition: all 0.4s ease;
  }

  .filter-btn::after {
    content: '';
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 2px;
    background-color: var(--orange);
    transition: width 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }

  .filter-btn:hover {
    color: var(--primary);
  }

  .filter-btn:hover::after, .filter-btn.active::after {
    width: 100%;
  }

  .filter-btn.active {
    color: var(--orange);
  }

  .results-count {
    color: #9ca3af;
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1.2px;
  }

  /* Projects Gallery */
  .gallery-section {
    background-color: white;
    padding: 80px 0;
  }

  .gallery-grid {
    display: flex;
    gap: 30px;
  }

  .column {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 60px;
  }

  .column.offset {
    margin-top: 80px;
  }

  .project-card {
    display: flex;
    flex-direction: column;
    gap: 20px;
    cursor: pointer;
    transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    border-radius: 12px;
  }

  .project-card:hover {
    transform: translateY(-15px);
  }

  .image-wrapper {
    position: relative;
    width: 100%;
    aspect-ratio: 613 / 516;
    border-radius: 8px;
    overflow: hidden;
    transition: box-shadow 0.5s ease;
  }

  .project-card:hover .image-wrapper {
    box-shadow: 0 40px 80px rgba(0, 0, 0, 0.15);
  }

  .project-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.8s cubic-bezier(0.4, 0, 0.2, 1);
  }

  .project-card:hover .project-img {
    transform: scale(1.15) rotate(1deg);
  }

  .logo-overlay {
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    display: flex;
    align-items: center;
    gap: 24px;
    width: 90%;
    justify-content: center;
    filter: drop-shadow(0 10px 20px rgba(0, 0, 0, 0.4));
    transition: all 0.5s ease;
  }

  .project-card:hover .logo-overlay {
    transform: translate(-50%, -55%) scale(1.1);
  }

  .logomark {
    height: 120px; /* BIG Logos */
    width: auto;
  }

  .logotext {
    height: 80px; /* BIG Logos */
    width: auto;
  }

  .project-info h3 {
    font-size: 18px;
    font-weight: 700;
    color: #0a0a0a;
    text-transform: uppercase;
    margin-bottom: 4px;
    letter-spacing: -0.36px;
  }

  .project-info p {
    font-size: 14px;
    color: #0a0a0a;
    opacity: 0.6;
  }

  /* CTA Section - Floating Card Style */
  .cta-section {
    background-color: transparent; /* Changed to transparent to show 'card' */
    padding: 60px 40px; /* Surrounding space */
    position: relative;
    width: 100%;
    background-color: white; /* Behind the card */
  }

  .cta-card {
    background-color: #ff612c;
    border-radius: 40px;
    padding: 100px 40px;
    position: relative;
    overflow: hidden;
    color: #231661;
    text-align: center;
    max-width: 1440px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    box-shadow: 0 20px 60px rgba(255, 97, 44, 0.15);
  }

  .cta-bg-wrapper {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0.1;
    pointer-events: none;
    z-index: 0;
  }

  .cta-bg-text {
    font-family: 'Anton SC', sans-serif;
    font-size: 200px;
    font-weight: 900;
    color: white;
    line-height: 1;
    text-transform: uppercase;
    letter-spacing: -2px;
  }

  .cta-content {
    position: relative;
    z-index: 1;
    width: 100%;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .cta-title {
    font-size: 64px;
    font-weight: 900;
    line-height: 1.1;
    letter-spacing: -1.5px;
    text-transform: uppercase;
    color: #231661;
    margin-bottom: 32px;
  }

  .white-text {
    color: white;
  }

  .cta-btn {
    background-color: #231661;
    color: white;
    padding: 24px 48px;
    border-radius: 9999px;
    font-size: 18px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 1.8px;
    box-shadow: 0 4px 4px rgba(0,0,0,0.25);
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    text-decoration: none;
  }

  .cta-btn:hover {
    transform: scale(1.05) translateY(-5px);
    box-shadow: 0 10px 20px rgba(0,0,0,0.3);
  }

  /* Responsive Refinements - 'Perfect' Mobile Fixes */
  @media (max-width: 1200px) {
    .container {
      padding: 0 40px;
    }
    .hero-title, .cta-title {
      font-size: 64px;
      letter-spacing: -2.5px;
    }
    .marquee-item {
      font-size: 150px;
    }
  }

  @media (max-width: 768px) {
    .work-hero, .gallery-section, .cta-section {
      padding: 80px 0;
    }
    .hero-title, .cta-title {
      font-size: 40px !important;
      letter-spacing: -1.5px;
    }
    .hero-bg-text, .cta-bg-text {
      font-size: 100px !important;
    }
    .gallery-grid {
      flex-direction: column;
      gap: 40px;
    }
    .column.offset {
      margin-top: 0;
    }
    .filters {
      gap: 20px;
      overflow-x: auto;
      padding-bottom: 20px;
      justify-content: flex-start;
      margin-left: -20px;
      padding-left: 20px;
    }
    .filter-btn {
      font-size: 12px;
    }
    .results-count {
      display: none;
    }
    .cta-card {
      padding: 60px 24px;
      border-radius: 20px;
    }
    .cta-btn {
      padding: 16px 32px;
      font-size: 16px;
    }
    .logomark {
      height: 80px;
    }
    .logotext {
      height: 48px;
    }
  }

</style>
