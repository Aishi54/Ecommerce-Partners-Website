---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Testimonials from "../components/Testimonials.astro";

const services = [
  {
    title: "Website Design & Development",
    icon: "M12 2L2 7l10 5 10-5-10-5zM2 17l10 5 10-5M2 12l10 5 10-5",
    points: ["Shopify Specialists", "Custom Web Apps", "E-commerce Architecture", "Performance Optimization"]
  },
  {
    title: "Mobile App Development",
    icon: "M12 18h.01M8 21h8a2 2 0 002-2V5a2 2 0 00-2-2H8a2 2 0 00-2 2v14a2 2 0 002 2z",
    points: ["iOS Native Apps", "Android Ecosystem", "React Native / Flutter", "API Integration"]
  },
  {
    title: "Branding & Identity",
    icon: "M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z",
    points: ["Strategic Logo Design", "Visual Identity Systems", "Brand Messaging", "Style Guides"]
  },
  {
    title: "Digital Marketing & SEO",
    icon: "M22 12h-4l-3 9L9 3l-3 9H2",
    points: ["Performance Marketing", "SEO Audit & Strategy", "Content Marketing", "Conversion Optimization"]
  },
  {
    title: "UI/UX Design",
    icon: "M12 22C6.477 22 2 17.523 2 12S6.477 2 12 2s10 4.477 10 10-4.477 10-10 10zm0-2a8 8 0 100-16 8 8 0 000 16z",
    points: ["User Research", "High-Fidelity Prototyping", "Interaction Design", "Usability Testing"]
  }
];

const steps = [
  { num: "01", title: "Discovery", desc: "Deep dive into your business goals, target audience, and competition to build a solid foundation." },
  { num: "02", title: "Design", desc: "Creating visual concepts and user experiences that captivate and convert your users." },
  { num: "03", title: "Development", desc: "Turning designs into functional, high-performance code using modern tech stacks." },
  { num: "04", title: "Launch", desc: "Final testing, deployment, and ongoing optimization to ensure sustained growth." }
];
---

<Layout title="Services - Ecommerce Partners">
  <Header />

  <main>
    <!-- Hero Section -->
    <section class="services-hero">
      <div class="hero-bg-text">
        <div class="marquee-track">
          <div class="marquee-item">
            OUR SOLUTIONS — EXPERT SERVICES — DIGITAL GROWTH — ECOMMERCE —
          </div>
          <div class="marquee-item" aria-hidden="true">
            OUR SOLUTIONS — EXPERT SERVICES — DIGITAL GROWTH — ECOMMERCE —
          </div>
        </div>
      </div>
      <div class="container hero-content">
        <h1 class="hero-title">OUR <br /><span class="highlight">SERVICES</span></h1>
        <p class="hero-subtitle">• CREATIVE AS IT SHOULD BE</p>
      </div>
    </section>

    <!-- Solutions Section -->
    <section class="solutions-section">
      <div class="container">
        <div class="solutions-header">
          <h2 class="solutions-title">
            <span class="solutions-primary">COMPREHENSIVE</span> <br /> 
            <span class="solutions-accent">DIGITAL SOLUTIONS.</span>
          </h2>
        </div>
        
        <div class="services-grid">
          {services.map(service => (
            <div class="service-card">
              <div class="service-icon">
                <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d={service.icon} />
                </svg>
              </div>
              <h3 class="service-title">{service.title}</h3>
              <ul class="service-points">
                {service.points.map(point => (
                  <li>
                    <span class="dot"></span>
                    {point}
                  </li>
                ))}
              </ul>
            </div>
          ))}
          
          <div class="quote-card">
            <p class="quote-text">We love tackling complex problems that don't fit into a box.</p>
            <a href="/contact" class="card-cta-btn">START YOUR PROJECT</a>
          </div>
        </div>
      </div>
    </section>

    <!-- Workflow Section -->
    <section class="workflow-section">
      <div class="container overflow-hidden position-relative">
        <div class="workflow-header">
           <span class="workflow-tag">• THE FLOW</span>
           <h2 class="workflow-title">HOW WE WORK</h2>
        </div>
        
        <div class="steps-grid">
          {steps.map(step => (
            <div class="step-item">
              <span class="step-num">{step.num}</span>
              <div class="step-content">
                <h4 class="step-title">{step.title}</h4>
                <p class="step-desc">{step.desc}</p>
              </div>
            </div>
          ))}
        </div>
        
        <div class="workflow-decoration"></div>
      </div>
    </section>

    <!-- Testimonials Section -->
    <Testimonials />

    <!-- CTA Section -->
    <section class="cta-section">
      <div class="cta-card">
        <div class="cta-bg-wrapper">
          <div class="cta-bg-text">START</div>
        </div>
        <div class="container cta-content">
          <h2 class="cta-title">READY TO START <br /> A <span class="white-text">PROJECT?</span></h2>
          <a href="/contact" class="cta-btn">
            <span>GET IN TOUCH —&gt;</span>
          </a>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  main {
    background-color: var(--primary);
  }

  /* Hero Section */
  .services-hero {
    padding: 160px 0 80px;
    position: relative;
    overflow: hidden;
    color: white;
  }

  .hero-bg-text {
    position: absolute;
    top: 50%;
    left: 0;
    width: 100%;
    transform: translateY(-50%);
    pointer-events: none;
    opacity: 0.1;
    z-index: 0;
    white-space: nowrap;
    overflow: hidden;
  }

  .marquee-track {
    display: flex;
    width: max-content;
    animation: scroll-right 50s linear infinite;
  }

  .marquee-item {
    font-family: "Anton SC", sans-serif;
    font-size: 250px;
    line-height: 1;
    color: #fff;
    padding-right: 100px;
    text-transform: uppercase;
  }

  @keyframes scroll-right {
    0% {
      transform: translateX(-50%);
    }
    100% {
      transform: translateX(0);
    }
  }

  .hero-content {
    position: relative;
    z-index: 1;
  }

  .hero-title {
    font-size: 80px;
    font-weight: 900;
    line-height: 1;
    letter-spacing: -4px;
    text-transform: uppercase;
    margin-bottom: 20px;
  }

  .highlight {
    color: #ff5c26;
  }

  .hero-subtitle {
    font-size: 18px;
    font-weight: 700;
    color: #ccff00;
    letter-spacing: 1px;
  }

  /* Solutions Section - Premium Overhaul */
  .solutions-section {
    background-color: #f8f9fb;
    padding: 120px 0;
  }

  .container {
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 40px;
  }

  .solutions-header {
    margin-bottom: 60px;
    text-align: left;
  }

  .solutions-title {
    font-size: 80px;
    font-weight: 700;
    line-height: 1;
    letter-spacing: -4px;
    text-transform: uppercase;
  }

  .solutions-primary {
    color: var(--primary);
  }

  .solutions-accent {
    color: var(--orange);
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px; /* Tighter gap */
    background-color: transparent;
    border: none;
  }

  .service-card {
    background-color: white;
    padding: 40px 32px; /* More compact */
    border-radius: 24px;
    display: flex;
    flex-direction: column;
    height: 100%;
    transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
    border: 1px solid rgba(0,0,0,0.04);
    position: relative;
    box-shadow: 0 10px 40px rgba(0,0,0,0.02);
  }

  .service-card:hover {
    transform: translateY(-12px);
    box-shadow: 0 30px 60px rgba(35, 22, 97, 0.05);
    border-color: rgba(255, 97, 44, 0.12);
  }

  .service-icon {
    width: 40px;
    height: 40px;
    margin-bottom: 24px;
    color: #ff612c;
    transition: all 0.5s ease;
  }

  .service-card:hover .service-icon {
    transform: scale(1.1) rotate(-5deg);
  }

  .service-title {
    font-size: 18px; /* More minimal */
    font-weight: 700;
    color: var(--primary);
    text-transform: uppercase;
    letter-spacing: -0.5px;
    margin-bottom: 24px;
    line-height: 1.1;
  }

  .service-points {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .service-points li {
    display: flex;
    align-items: center;
    gap: 12px;
    color: #555;
    font-size: 14px;
    font-weight: 500;
    transition: all 0.4s ease;
    transform: translateX(0);
    opacity: 0.9;
  }

  .service-card:hover li {
    transform: translateX(6px);
    color: var(--primary);
  }

  .service-card:hover li:nth-child(1) { transition-delay: 0.05s; }
  .service-card:hover li:nth-child(2) { transition-delay: 0.1s; }
  .service-card:hover li:nth-child(3) { transition-delay: 0.15s; }
  .service-card:hover li:nth-child(4) { transition-delay: 0.2s; }

  .dot {
    width: 6px;
    height: 6px;
    background-color: #ff612c;
    rotate: 45deg;
    flex-shrink: 0;
    transition: all 0.4s ease;
  }

  .service-card:hover .dot {
    border-radius: 50%;
    transform: scale(1.1);
  }

  .quote-card {
    background-color: #231661;
    padding: 40px 32px;
    border-radius: 24px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: flex-start;
    height: 100%;
    position: relative;
    transition: all 0.6s cubic-bezier(0.16, 1, 0.3, 1);
  }

  .quote-card:hover {
    transform: translateY(-8px);
    box-shadow: 0 20px 40px rgba(35, 22, 97, 0.25);
  }

  .quote-text {
    color: white;
    font-size: 18px; /* More minimal */
    font-weight: 700;
    line-height: 1.2;
    margin-bottom: 24px;
    text-transform: uppercase;
    letter-spacing: -0.5px;
  }

  .quote-link {
    display: none; /* Replaced */
  }

  .card-cta-btn {
    background-color: #ccff00;
    color: #231661;
    padding: 16px 32px;
    border-radius: 9999px;
    font-size: 13px;
    font-weight: 900;
    text-transform: uppercase;
    letter-spacing: 1.5px;
    text-decoration: none;
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    display: inline-block;
    box-shadow: 0 4px 10px rgba(0,0,0,0.1);
  }

  .card-cta-btn:hover {
    transform: translateY(-5px) scale(1.05);
    background-color: white;
    box-shadow: 0 15px 30px rgba(204, 255, 0, 0.2);
  }

  /* Responsive Refinements */
  @media (max-width: 1200px) {
    .container {
      padding: 0 40px;
    }
    .solutions-title, .workflow-title {
      font-size: 60px;
      letter-spacing: -2.5px;
    }
    .services-grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 20px;
    }
  }

  @media (max-width: 900px) {
    .steps-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .solutions-section, .workflow-section {
      padding: 80px 0;
    }
    .solutions-title, .workflow-title {
      font-size: 40px;
      letter-spacing: -1.5px;
    }
    .services-grid, .steps-grid {
      grid-template-columns: 1fr;
      gap: 24px;
    }
    .solutions-header, .workflow-header {
      margin-bottom: 40px;
    }
    .service-card {
      padding: 32px 24px;
    }
    .service-title {
      font-size: 16px;
    }
    .quote-text {
      font-size: 16px;
    }
  }

  .workflow-header {
    text-align: left;
    margin-bottom: 80px;
  }

  .workflow-tag {
    color: #ccff00;
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 2px;
    display: block;
    margin-bottom: 24px;
    text-transform: uppercase;
  }

  .workflow-title {
    font-size: 80px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: -4px;
    line-height: 1;
  }

  .steps-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 40px;
  }

  .step-item {
    position: relative;
    transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
    padding: 20px;
    border-radius: 20px;
  }

  .step-item:hover {
    background-color: rgba(255,255,255,0.03);
    transform: translateY(-10px);
  }

  .step-num {
    font-size: 120px;
    font-weight: 900;
    color: white;
    opacity: 0.05;
    position: absolute;
    top: -40px;
    left: -10px;
    pointer-events: none;
    transition: all 0.6s ease;
  }

  .step-item:hover .step-num {
    opacity: 0.2;
    transform: scale(1.1) translateX(10px);
    color: #ff612c;
  }

  .step-content {
    position: relative;
    z-index: 1;
  }

  .step-title {
    font-size: 20px;
    font-weight: 800;
    color: var(--orange);
    margin-bottom: 20px;
    text-transform: uppercase;
    letter-spacing: 1px;
    position: relative;
    display: inline-block;
  }

  .step-title::after {
    content: '';
    position: absolute;
    bottom: -8px;
    left: 0;
    width: 30px;
    height: 3px;
    background-color: #ccff00;
    transition: width 0.4s ease;
  }

  .step-item:hover .step-title::after {
    width: 100%;
  }

  .step-desc {
    font-size: 15px;
    color: #aeaeae;
    line-height: 1.6;
    font-weight: 400;
  }

  .workflow-decoration {
    position: absolute;
    top: -50px;
    right: -50px;
    width: 300px;
    height: 300px;
    border: 1px solid rgba(204, 255, 0, 0.2);
    border-radius: 50%;
    pointer-events: none;
    animation: slow-pulse 8s ease-in-out infinite;
  }

  @keyframes slow-pulse {
    0%, 100% { transform: scale(1) translate(0, 0); opacity: 0.2; }
    50% { transform: scale(1.2) translate(10px, 10px); opacity: 0.4; }
  }

  /* Staggered Row Animation - Handled by class on load/scroll if needed, but adding basic keyframes */
  .step-item {
    opacity: 0;
    animation: fade-up 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  .step-item:nth-child(1) { animation-delay: 0.1s; }
  .step-item:nth-child(2) { animation-delay: 0.2s; }
  .step-item:nth-child(3) { animation-delay: 0.3s; }
  .step-item:nth-child(4) { animation-delay: 0.4s; }

  @keyframes fade-up {
    from { opacity: 0; transform: translateY(40px); }
    to { opacity: 1; transform: translateY(0); }
  }

  /* CTA Section - Floating Card Style */
  .cta-section {
    background-color: transparent;
    padding: 60px 40px;
    position: relative;
    width: 100%;
    background-color: white;
  }

  .cta-card {
    background-color: #ff612c;
    border-radius: 40px;
    padding: 100px 40px;
    position: relative;
    overflow: hidden;
    color: #231661;
    text-align: center;
    max-width: 1440px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
    box-shadow: 0 20px 60px rgba(255, 97, 44, 0.15);
  }

  .cta-bg-wrapper {
    position: absolute;
    inset: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0.1;
    pointer-events: none;
    z-index: 0;
  }

  .cta-bg-text {
    font-family: 'Anton SC', sans-serif;
    font-size: 200px;
    font-weight: 900;
    color: white;
    line-height: 1;
    text-transform: uppercase;
    letter-spacing: -2px;
  }

  .cta-content {
    position: relative;
    z-index: 1;
    width: 100%;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .cta-title {
    font-size: 64px;
    font-weight: 900;
    line-height: 1.1;
    letter-spacing: -1.5px;
    text-transform: uppercase;
    color: #231661;
    margin-bottom: 32px;
  }

  .white-text {
    color: white;
  }

  .cta-btn {
    background-color: #231661;
    color: white;
    padding: 24px 48px;
    border-radius: 9999px;
    font-size: 18px;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 1.8px;
    box-shadow: 0 4px 4px rgba(0,0,0,0.25);
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    text-decoration: none;
  }

  .cta-btn:hover {
    transform: scale(1.05) translateY(-5px);
    box-shadow: 0 10px 20px rgba(0,0,0,0.3);
  }

  @media (max-width: 1024px) {
    .hero-title, .workflow-title, .cta-title {
      font-size: 60px;
    }
    .hero-bg-text, .cta-bg-text {
      font-size: 150px;
    }
    .services-grid {
      grid-template-columns: repeat(2, 1fr);
    }
    .steps-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 768px) {
    .services-grid {
      grid-template-columns: 1fr;
    }
    .steps-grid {
      grid-template-columns: 1fr;
    }
    .hero-title {
      font-size: 48px;
    }
  }
</style>
