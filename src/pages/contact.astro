---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
const faqData = [
  {
    question: "What e-commerce platforms do you specialize in?",
    answer: "We specialize in Shopify, WooCommerce, and custom headless e-commerce solutions, ensuring your brand has the right foundation for scaling.",
    active: true
  },
  {
    question: "How long does a typical store launch take?",
    answer: "Project timelines vary based on complexity, but most high-end e-commerce stores are designed, developed, and launched within 4-8 weeks.",
    active: false
  },
  {
    question: "Do you offer post-launch optimization?",
    answer: "Absolutely. We offer ongoing maintenance, SEO audits, and conversion rate optimization (CRO) to ensure your store continues to grow after launch.",
    active: false
  },
  {
    question: "Can you migrate my store from another platform?",
    answer: "Yes, we handle full-scale migrations from platforms like Magento, BigCommerce, or Squarespace, ensuring all your customer data and SEO ranking stay intact.",
    active: false
  }
];
---

<Layout title="Contact Us - Ecommerce Partners">
  <Header />

  <main>
    <!-- Hero Section -->
    <section class="contact-hero">
      <div class="hero-bg-text">
        <div class="marquee-track">
          <div class="marquee-item">
            SAY HELLO — CONTACT US — GET IN TOUCH — LET'S TALK —
          </div>
          <div class="marquee-item" aria-hidden="true">
            SAY HELLO — CONTACT US — GET IN TOUCH — LET'S TALK —
          </div>
        </div>
      </div>

      <div class="container hero-content">
        <span class="contact-tag">• Get in touch</span>
        <h1 class="hero-title">
          LET'S CREATE <br />
          <span class="highlight">SOMETHING</span> <br />
          AMAZING.
        </h1>
        <p class="hero-desc">
          A talented team brings creative visions to life, ensuring each project reflects clients' essence. Segoe delivers exceptional results that elevate your online presence.
        </p>
      </div>
    </section>

    <!-- Main Contact Section -->
    <section class="main-contact">
      <div class="container contact-split">
        <!-- Form Column -->
        <div class="form-column">
          <h2 class="form-title">SEND US A MESSAGE</h2>
          <form 
            id="contact-form"
            action="https://formspree.io/f/nazarayesha547@gmail.com" 
            method="POST"
            class="contact-form"
          >
            <div class="form-row">
              <div class="form-group">
                <label>YOUR NAME</label>
                <input type="text" name="name" placeholder="John Doe" required />
              </div>
              <div class="form-group">
                <label>EMAIL ADDRESS</label>
                <input type="email" name="email" placeholder="john@example.com" required />
              </div>
            </div>
            <div class="form-group">
              <label>SUBJECT</label>
              <input type="text" name="subject" placeholder="Project Inquiry" required />
            </div>
            <div class="form-group">
              <label>MESSAGE</label>
              <textarea name="message" placeholder="Tell us about your project..." required></textarea>
            </div>
            <button type="submit" id="submit-btn" class="submit-btn">
              <span class="btn-text">SEND MESSAGE</span>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" class="btn-icon">
                <path d="M14.43 5.93L20.5 12l-6.07 6.07M3.5 12h16.83" stroke="white" stroke-width="2" stroke-miterlimit="10" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
          </form>

          <!-- Success Message -->
          <div id="success-msg" class="success-msg">
            <div class="success-icon">
              <svg width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="#d1f836" stroke-width="3">
                <path d="M20 6L9 17L4 12" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <h3>MESSAGE SENT!</h3>
            <p>We've received your inquiry and will get back to you within 24 hours. Let's create something amazing!</p>
            <button class="reset-btn" onclick="location.reload()">SEND ANOTHER</button>
          </div>
        </div>

        <!-- Info Column -->
        <div class="info-column">
          <div class="info-group">
            <span class="info-tag">Location</span>
            <p class="info-text">Jl. Raya Seminyak No. 88, <br />Seminyak, Bali, Indonesia</p>
          </div>
          <div class="info-group">
            <span class="info-tag">Call Us</span>
            <p class="info-text">+62 813 3376 1890</p>
            <p class="info-text opacity-60">your@email.com</p>
          </div>
          <div class="social-links">
            <a href="#" aria-label="Instagram">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg>
            </a>
            <a href="#" aria-label="LinkedIn">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"></path><rect x="2" y="9" width="4" height="12"></rect><circle cx="4" cy="4" r="2"></circle></svg>
            </a>
            <a href="#" aria-label="Dribbble">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"></circle><path d="M8.56 2.75c4.37 6.03 6.02 9.42 8.03 17.72m2.54-15.38c-3.72 4.35-8.94 5.66-16.13 5.5m3.07 13.2c3.97-3.66 6.06-6.02 12.76-5.81"></path></svg>
            </a>
          </div>
        </div>
      </div>
    </section>
    <!-- FAQ Section -->
    <section class="faq-section">
      <div class="container">
        <div class="faq-header">
          <h2 class="faq-title">FREQUENTLY <br /><span class="highlight">ASKED</span> QUESTIONS</h2>
        </div>
        
        <div class="faq-list">
          {faqData.map((item, index) => (
            <>
              <div class={`faq-item ${index === 0 ? 'active' : ''}`}>
                <div class="faq-question">
                  <h3>{item.question}</h3>
                  <div class="faq-toggle">
                    <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
                      <path d="M7 17L17 7M17 7H7M17 7V17" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                    </svg>
                  </div>
                </div>
                <div class="faq-answer">
                  <p>{item.answer}</p>
                </div>
              </div>
              {index < faqData.length - 1 && <div class="faq-divider"></div>}
            </>
          ))}
        </div>
      </div>
    </section>

    <script>
      // Form Submission Logic - 100% DIRECT FIX
      const contactForm = document.getElementById('contact-form') as HTMLFormElement;
      const submitBtn = document.getElementById('submit-btn');
      const successMsg = document.getElementById('success-msg');

      if (contactForm && submitBtn && successMsg) {
        contactForm.addEventListener('submit', (e) => {
          e.preventDefault();
          
          // Start Visual Loading
          submitBtn.classList.add('loading');
          const btnText = submitBtn.querySelector('.btn-text');
          if (btnText) btnText.textContent = "SENDING...";

          const formData = new FormData(contactForm);
          const name = formData.get('name');
          const email = formData.get('email');
          const subject = formData.get('subject');
          const message = formData.get('message');

          // Construct professional mailto body
          const body = `Name: ${name}%0D%0AEmail: ${email}%0D%0A%0D%0AMessage:%0D%0A${message}`;
          
          // Trigger DIRECT MAILTO to bypass all services
          window.location.href = `mailto:nazarayesha547@gmail.com?subject=Project Inquiry - ${subject}&body=${body}`;

          // Show Success UI regardless for professional feel
          setTimeout(() => {
            contactForm.style.display = 'none';
            successMsg.style.display = 'flex';
          }, 1000);
        });
      }

      // FAQ Accordion Logic
      const faqItems = document.querySelectorAll('.faq-item');
      faqItems.forEach(item => {
        item.addEventListener('click', () => {
          faqItems.forEach(i => i.classList.remove('active'));
          item.classList.add('active');
        });
      });
    </script>
  </main>

  <Footer />
</Layout>

<style>
  main {
    background-color: var(--primary);
    color: white;
  }

  /* Hero Section */
  .contact-hero {
    padding: 160px 0 80px;
    position: relative;
    overflow: hidden;
    background-color: var(--primary);
  }

  .hero-bg-text {
    position: absolute;
    top: 50%;
    left: 0;
    width: 100%;
    transform: translateY(-50%);
    pointer-events: none;
    opacity: 0.1;
    z-index: 0;
    white-space: nowrap;
    overflow: hidden;
  }

  .marquee-track {
    display: flex;
    width: max-content;
    animation: scroll-right 50s linear infinite;
  }

  .marquee-item {
    font-family: "Anton SC", sans-serif;
    font-size: 250px;
    line-height: 1;
    color: #fff;
    padding-right: 100px;
    text-transform: uppercase;
  }

  @keyframes scroll-right {
    0% {
      transform: translateX(-50%);
    }
    100% {
      transform: translateX(0);
    }
  }

  .hero-content {
    position: relative;
    z-index: 1;
  }

  .contact-tag {
    color: var(--orange);
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    display: block;
    margin-bottom: 16px;
  }

  .hero-title {
    font-size: 80px;
    font-weight: 900;
    line-height: 1;
    letter-spacing: -3px;
    text-transform: uppercase;
    margin-bottom: 24px;
  }

  .highlight {
    color: var(--orange);
  }

  .hero-desc {
    font-size: 16px;
    line-height: 1.6;
    max-width: 500px;
    opacity: 0.7;
  }

  .hero-star {
    position: absolute;
    top: 50%;
    right: 0px;
    transform: translateY(-50%);
    width: 140px;
    height: auto;
    animation: rotate 20s linear infinite;
    z-index: -1;
    filter: drop-shadow(0 0 30px rgba(209, 248, 54, 0.2));
  }

  @keyframes rotate {
    from { transform: translateY(-50%) rotate(0deg); }
    to { transform: translateY(-50%) rotate(360deg); }
  }

  @media (max-width: 1024px) {
    .hero-star {
      width: 100px;
      right: -20px;
      top: 20%;
    }
  }

  .hero-decoration {
    position: absolute;
    top: 160px;
    right: 80px;
    width: 100px;
    opacity: 0.2;
  }

  /* Main Contact Section */
  .main-contact {
    padding: 60px 0 100px;
  }

  .contact-split {
    display: flex;
    gap: 80px;
    align-items: flex-start;
  }

  .form-column {
    flex: 1.5;
  }

  .info-column {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 64px;
  }

  .form-title {
    font-size: 30px;
    font-weight: 700;
    margin-bottom: 48px;
    text-transform: uppercase;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .form-row {
    display: flex;
    gap: 32px;
  }

  .form-group {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .form-group label {
    font-size: 12px;
    font-weight: 400;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    opacity: 0.5;
  }

  .form-group input, .form-group textarea {
    background-color: transparent;
    border: none;
    border-bottom: 2px solid rgba(255, 255, 255, 0.1);
    padding: 12px 16px;
    font-size: 16px;
    color: white;
    outline: none;
    transition: all 0.3s ease;
    padding-left: 0;
  }

  .form-group input::placeholder, .form-group textarea::placeholder {
    color: rgba(255, 255, 255, 0.3);
  }

  .form-group input:focus, .form-group textarea:focus {
    border-bottom-color: #d1f836;
    padding-left: 8px; /* Subtle movement effect */
  }

  .submit-btn {
    background-color: var(--orange);
    color: white;
    border: none;
    border-radius: 9999px;
    padding: 16px 40px;
    font-size: 16px;
    font-weight: 700;
    display: inline-flex;
    align-items: center;
    gap: 12px;
    width: fit-content;
    cursor: pointer;
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    margin-top: 24px;
    box-shadow: 0 10px 20px rgba(255, 92, 31, 0.2);
  }

  .submit-btn:hover {
    transform: translateY(-5px) scale(1.05);
    background-color: #ff7c4d;
    box-shadow: 0 15px 30px rgba(255, 92, 31, 0.4);
  }

  .submit-btn:hover .btn-icon {
    transform: translateX(5px);
  }

  .btn-icon {
    width: 20px;
    height: 20px;
    transition: transform 0.3s ease;
  }

  /* Info Column */
  .info-tag {
    color: #d1f836;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 2.4px;
    text-transform: uppercase;
    display: block;
    margin-bottom: 24px;
  }

  .info-text {
    font-size: 24px;
    font-weight: 700;
    line-height: 1.3;
    margin-bottom: 8px;
    transition: all 0.3s ease;
    cursor: pointer;
  }

  .info-text:hover {
    color: #d1f836;
    transform: translateX(5px);
  }

  .info-star-box {
    margin-bottom: -20px;
    margin-top: -40px;
  }

  .info-star {
    width: 100px;
    height: auto;
    animation: rotate 30s linear infinite reverse;
    filter: drop-shadow(0 0 20px rgba(209, 248, 54, 0.1));
  }

  .opacity-60 {
    opacity: 0.6;
  }

  .social-links {
    display: flex;
    gap: 16px;
    margin-top: 20px;
  }

  .social-links a {
    width: 52px;
    height: 52px;
    border-radius: 50%;
    border: 1.5px solid rgba(255, 255, 255, 0.15);
    display: flex;
    align-items: center;
    justify-content: center;
    color: white;
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }

  .social-links a:hover {
    color: var(--primary);
    background-color: #d1f836;
    border-color: #d1f836;
    transform: translateY(-5px) rotate(8deg);
    box-shadow: 0 10px 20px rgba(209, 248, 54, 0.3);
  }

  .social-links a svg {
    width: 22px;
    height: 22px;
    transition: transform 0.4s ease;
  }

  .social-links a:hover svg {
    transform: scale(1.1);
  }

  /* FAQ Section */
  .faq-section {
    background-color: white;
    padding: 100px 0;
    color: var(--primary);
  }

  .faq-header {
    margin-bottom: 60px;
  }

  .faq-title {
    font-size: 56px;
    font-weight: 800;
    line-height: 1.1;
    text-transform: uppercase;
    letter-spacing: -2px;
  }

  .faq-list {
    max-width: 900px;
    margin: 0 auto;
  }

  .faq-item {
    padding: 30px;
    cursor: pointer;
    transition: all 0.4s ease;
    border-radius: 20px;
  }

  .faq-item.active {
    background-color: #f1f0ff;
    padding: 40px;
  }

  .faq-question {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 20px;
  }

  .faq-question h3 {
    font-size: 24px;
    font-weight: 700;
    margin: 0;
    text-transform: uppercase;
  }

  .faq-toggle {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: #f1f0ff;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--primary);
    transition: all 0.4s ease;
    flex-shrink: 0;
  }

  .faq-item.active .faq-toggle {
    background: var(--primary);
    color: white;
    transform: rotate(45deg);
  }

  .faq-answer {
    max-height: 0;
    overflow: hidden;
    transition: all 0.4s ease;
    opacity: 0;
  }

  .faq-item.active .faq-answer {
    max-height: 200px;
    opacity: 0.8;
    margin-top: 16px;
  }

  .faq-answer p {
    font-size: 16px;
    line-height: 1.6;
    margin: 0;
    max-width: 700px;
  }

  .faq-divider {
    height: 1px;
    background: rgba(0,0,0,0.05);
    width: 100%;
    margin: 4px 0;
  }

  .faq-item.active + .faq-divider {
    opacity: 0;
  }

  /* Success Message Styling */
  .success-msg {
    display: none;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 40px;
    padding: 60px 40px;
    animation: fadeIn 0.6s ease;
  }

  @keyframes fadeIn {
    from { opacity: 0; transform: scale(0.95); }
    to { opacity: 1; transform: scale(1); }
  }

  .success-icon {
    width: 100px;
    height: 100px;
    background: rgba(209, 248, 54, 0.1);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 24px;
    animation: pulse 2s infinite;
  }

  @keyframes pulse {
    0% { transform: scale(1); box-shadow: 0 0 0 0 rgba(209, 248, 54, 0.4); }
    70% { transform: scale(1.05); box-shadow: 0 0 0 20px rgba(209, 248, 54, 0); }
    100% { transform: scale(1); box-shadow: 0 0 0 0 rgba(209, 248, 54, 0); }
  }

  .success-msg h3 {
    font-size: 32px;
    font-weight: 800;
    margin-bottom: 16px;
    color: white;
  }

  .success-msg p {
    font-size: 16px;
    opacity: 0.6;
    max-width: 400px;
    margin-bottom: 32px;
  }

  .reset-btn {
    background: transparent;
    border: 1px solid rgba(255, 255, 255, 0.2);
    color: white;
    padding: 12px 24px;
    border-radius: 999px;
    cursor: pointer;
    font-weight: 700;
    transition: all 0.3s ease;
  }

  .reset-btn:hover {
    background: white;
    color: var(--primary);
  }

  .submit-btn.loading {
    opacity: 0.7;
    pointer-events: none;
    cursor: wait;
  }

  .submit-btn.loading .btn-icon {
    animation: spin 1s linear infinite;
  }

  @keyframes spin {
    to { transform: rotate(360deg); }
  }

  .container {
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 80px;
  }

  @media (max-width: 1024px) {
    .hero-title {
      font-size: 80px;
    }
    .contact-split {
      flex-direction: column;
      gap: 60px;
    }
  }

  @media (max-width: 768px) {
    .hero-title {
      font-size: 48px;
    }
    .form-row {
      flex-direction: column;
      gap: 32px;
    }
  }
</style>
