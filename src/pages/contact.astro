---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
---

<Layout title="Contact Us - Ecommerce Partners">
  <Header />

  <main>
    <!-- Hero Section -->
    <section class="contact-hero">
      <div class="container hero-content">
        <span class="contact-tag">• Get in touch</span>
        <h1 class="hero-title">
          LET'S CREATE <br />
          <span class="highlight">SOMETHING</span> <br />
          AMAZING.
        </h1>
        <p class="hero-desc">
          A talented team brings creative visions to life, ensuring each project reflects clients' essence. Segoe delivers exceptional results that elevate your online presence.
        </p>
      </div>
      <img src="http://localhost:3845/assets/e7ffaa7df41cf0ba555d266396005cd3759bc7a2.svg" alt="" class="hero-decoration" />
    </section>

    <!-- Main Contact Section -->
    <section class="main-contact">
      <div class="container contact-split">
        <!-- Form Column -->
        <div class="form-column">
          <h2 class="form-title">SEND US A MESSAGE</h2>
          <form class="contact-form">
            <div class="form-row">
              <div class="form-group">
                <label>YOUR NAME</label>
                <input type="text" placeholder="John Doe" />
              </div>
              <div class="form-group">
                <label>EMAIL ADDRESS</label>
                <input type="email" placeholder="john@example.com" />
              </div>
            </div>
            <div class="form-group">
              <label>SUBJECT</label>
              <input type="text" placeholder="Project Inquiry" />
            </div>
            <div class="form-group">
              <label>MESSAGE</label>
              <textarea placeholder="Tell us about your project..."></textarea>
            </div>
            <button type="submit" class="submit-btn">
              SEND MESSAGE 
              <img src="http://localhost:3845/assets/c4baedc8352e1cf058cb6943c0fcdc13660e5dc9.svg" alt="" class="btn-icon" />
            </button>
          </form>
        </div>

        <!-- Info Column -->
        <div class="info-column">
          <div class="info-group">
            <span class="info-tag">Location</span>
            <p class="info-text">Jl. Raya Seminyak No. 88, <br />Seminyak, Bali, Indonesia</p>
          </div>
          <div class="info-group">
            <span class="info-tag">Call Us</span>
            <p class="info-text">+62 813 3376 1890</p>
            <p class="info-text opacity-60">your@email.com</p>
          </div>
          <div class="social-links">
            <a href="#">Instagram</a>
            <a href="#">LinkedIn</a>
            <a href="#">Dribbble</a>
          </div>
        </div>
      </div>
    </section>
  </main>

  <Footer />
</Layout>

<style>
  main {
    background-color: var(--primary);
    color: white;
  }

  /* Hero Section */
  .contact-hero {
    padding: 160px 0 80px;
    position: relative;
    overflow: hidden;
  }

  .hero-content {
    position: relative;
    z-index: 1;
  }

  .contact-tag {
    color: var(--orange);
    font-size: 14px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    display: block;
    margin-bottom: 16px;
  }

  .hero-title {
    font-size: 80px;
    font-weight: 900;
    line-height: 1;
    letter-spacing: -3px;
    text-transform: uppercase;
    margin-bottom: 24px;
  }

  .highlight {
    color: var(--orange);
  }

  .hero-desc {
    font-size: 16px;
    line-height: 1.6;
    max-width: 500px;
    opacity: 0.7;
  }

  .hero-decoration {
    position: absolute;
    top: 160px;
    right: 80px;
    width: 100px;
    opacity: 0.2;
  }

  /* Main Contact Section */
  .main-contact {
    padding: 60px 0 100px;
  }

  .contact-split {
    display: flex;
    gap: 80px;
    align-items: flex-start;
  }

  .form-column {
    flex: 1.5;
  }

  .info-column {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 64px;
  }

  .form-title {
    font-size: 30px;
    font-weight: 700;
    margin-bottom: 48px;
    text-transform: uppercase;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 32px;
  }

  .form-row {
    display: flex;
    gap: 32px;
  }

  .form-group {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .form-group label {
    font-size: 12px;
    font-weight: 400;
    letter-spacing: 1.2px;
    text-transform: uppercase;
    opacity: 0.5;
  }

  .form-group input, .form-group textarea {
    background-color: white;
    border: none;
    border-bottom: 1px solid #6b7280;
    padding: 12px 16px;
    font-size: 16px;
    color: #111827;
    outline: none;
  }

  .form-group textarea {
    background-color: transparent;
    color: white;
    border-bottom: 2px solid rgba(255,255,255,0.2);
    min-height: 120px;
    padding-left: 0;
  }

  .submit-btn {
    background-color: var(--orange);
    color: white;
    border: none;
    border-radius: 9999px;
    padding: 12px 32px;
    font-size: 16px;
    font-weight: 700;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    width: fit-content;
    cursor: pointer;
    transition: transform 0.3s ease;
    margin-top: 16px;
  }

  .submit-btn:hover {
    transform: translateY(-2px);
  }

  .btn-icon {
    width: 20px;
    height: 20px;
  }

  /* Info Column */
  .info-tag {
    color: #d1f836;
    font-size: 12px;
    font-weight: 700;
    letter-spacing: 2.4px;
    text-transform: uppercase;
    display: block;
    margin-bottom: 24px;
  }

  .info-text {
    font-size: 24px;
    font-weight: 700;
    line-height: 1.3;
    margin-bottom: 8px;
  }

  .opacity-60 {
    opacity: 0.6;
  }

  .social-links {
    display: flex;
    gap: 24px;
    opacity: 0.5;
    margin-top: 10px;
  }

  .social-links a {
    font-size: 16px;
    color: white;
    text-decoration: none;
  }

  .container {
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 80px;
  }

  @media (max-width: 1024px) {
    .hero-title {
      font-size: 80px;
    }
    .contact-split {
      flex-direction: column;
      gap: 60px;
    }
  }

  @media (max-width: 768px) {
    .hero-title {
      font-size: 48px;
    }
    .form-row {
      flex-direction: column;
      gap: 32px;
    }
  }
</style>
