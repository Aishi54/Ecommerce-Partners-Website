---
import Layout from "../layouts/Layout.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Team from "../components/Team.astro";

const stats = [
  { value: "10+", label: "Years Experience", color: "#291c6c" },
  { value: "250+", label: "Projects Delivered", color: "#d1f836" },
  { value: "15+", label: "Awards Won", color: "#291c6c" },
  { value: "100%", label: "Client Satisfaction", color: "#d1f836" },
];

const processSteps = [
  {
    number: "01",
    title: "Discovery & Strategy",
    description: "We dive deep into your brand's DNA, identifying key performance indicators and mapping a data-driven path to e-commerce success."
  },
  {
    number: "02",
    title: "High-End Design",
    description: "Our design team crafts bespoke, high-converting interfaces that reflect your brand's essence and prioritize seamless user journeys."
  },
  {
    number: "03",
    title: "Expert Development",
    description: "Using cutting-edge technologies like Astro and Shopify, we build lightning-fast, scalable stores that look as good as they perform."
  },
  {
    number: "04",
    title: "Launch & Scaling",
    description: "Beyond launch, we continuously monitor performance and optimize for conversion, ensuring your brand scales efficiently and sustainably."
  }
];

const values = [
  {
    title: "CONVERSION-FOCUSED DEVELOPMENT",
    description:
      "From product pages to checkout optimization, every element is built to increase sales and maximize average order value.",
    active: true,
  },
  {
    title: "MULTI-PLATFORM EXPERTISE",
    description: "",
    active: false,
  },
  {
    title: "Speed OPTIMIZATION",
    description: "",
    active: false,
  },
  {
    title: "Data-Driven Scalling",
    description: "",
    active: false,
  },
];
---

<Layout title="About Us - Ecommerce Partners">
  <Header />

  <main>
    <!-- Hero Section -->
    <section class="about-hero">
      <div class="hero-bg-text">
        <div class="marquee-track">
          <div class="marquee-item">
            WHO WE ARE — ABOUT US — OUR STORY — OUR VISION —
          </div>
          <div class="marquee-item" aria-hidden="true">
            WHO WE ARE — ABOUT US — OUR STORY — OUR VISION —
          </div>
        </div>
      </div>

      <div class="container hero-container">
        <div class="hero-content">
          <h1 class="hero-title">
            WHO <br /> WE <span class="highlight">ARE</span>
          </h1>
          <p class="hero-description">
            A TALENTED TEAM BRINGS CREATIVE VISIONS TO LIFE, ENSURING EACH
            PROJECT REFLECTS CLIENTS' ESSENCE. SEGOE DELIVERS EXCEPTIONAL
            RESULTS THAT ELEVATE YOUR ONLINE PRESENCE.
          </p>
          <a href="#mission" class="cta-button">
            LEARN MORE <span>→</span>
          </a>
        </div>
        <div class="hero-image-wrapper">
          <img
            src="/images/hero-main.png"
            alt="Team at work"
            class="hero-img"
          />
          <img src="/images/asterisk.png" alt="" class="hero-asterisk" />
        </div>
      </div>
    </section>

    <section class="stats-section">
      <div class="container stats-container">
        <div class="stats-marquee-track">
          {
            // Triple mapping for the infinite marquee loop
            [...stats, ...stats, ...stats].map((stat) => (
              <div class="stat-item">
                <h2 class="stat-value" style={`color: ${stat.color}`}>
                  {stat.value}
                </h2>
                <p class="stat-label">{stat.label}</p>
              </div>
            ))
          }
        </div>
      </div>
    </section>

    <!-- Mission Section -->
    <section class="mission-section">
      <div class="container mission-container">
        <div class="mission-text">
          <span class="mission-tag">• Our Mission</span>
          <h2 class="mission-title">
            KNOWN FOR OUR INNOVATIVE APPROACH, WE SPECIALIZE IN STUNNING
            WEBSITES.
          </h2>
          <p class="mission-description">
            We bridge the gap between imagination and reality. Our vision is to
            empower brands with cutting-edge digital solutions that don't just
            look good but perform exceptionally in the modern landscape.
          </p>
        </div>
        <div class="mission-images">
          <img
            src="/images/about_mission_1.png"
            alt="Innovative Shopify Design"
            class="mission-img-1"
          />
          <img 
            src="/images/about_mission_2.png" 
            alt="Expert Shopify Scaling" 
            class="mission-img-2" 
          />
        </div>
      </div>
    </section>

    <!-- Values Section (Capabilities Style) -->
    <section class="values-section">
      <div class="container cap-container">
        <div class="values-header-top">
          <h2 class="values-title">
            OUR CORE <br /><span class="highlight">VALUES</span>
          </h2>
        </div>

        <div class="cap-content">
          <div class="cap-left">
            <div class="cap-image">
              <img src="/images/capabilities.png" alt="Our Core Values" class="cap-main-img" />
              <div class="cap-tag">• OUR CORE VALUES</div>
            </div>
          </div>
          
          <div class="cap-right">
            {
              values.map((value, index) => (
                <>
                  <div class={`capability-item ${index === 0 ? "active" : ""}`}>
                    <div class="cap-info">
                      <h3>{value.title}</h3>
                      <div class="cap-desc">
                        <p>{value.description || "Leading with innovation and data-driven insights to deliver world-class e-commerce solutions that scale seamlessly."}</p>
                      </div>
                    </div>
                    <div class="cap-arrow">
                      <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
                        <path d="M7 17L17 7M17 7H7M17 7V17" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
                      </svg>
                    </div>
                  </div>
                  {index < values.length - 1 && <div class="divider"></div>}
                </>
              ))
            }
          </div>
        </div>
      </div>
    </section>

    <script>
      const items = document.querySelectorAll('.capability-item');
      items.forEach(item => {
        item.addEventListener('click', () => {
          items.forEach(i => i.classList.remove('active'));
          item.classList.add('active');
        });
      });
    </script>

    <!-- Process Section -->
    <section class="process-section" id="process">
      <div class="container">
        <div class="process-header">
          <span class="process-tag">• Our Workflow</span>
          <h2 class="process-title">OUR STRATEGIC <span class="highlight">PROCESS</span></h2>
        </div>

        <div class="process-grid">
          {processSteps.map((step) => (
            <div class="process-card">
              <div class="process-number">{step.number}</div>
              <div class="process-card-content">
                <h3>{step.title}</h3>
                <p>{step.description}</p>
              </div>
              <div class="process-glow"></div>
            </div>
          ))}
        </div>
      </div>
    </section>

    <!-- Team Section -->
    <Team />
  </main>

  <Footer />
</Layout>

<style>
  main {
    background-color: var(--primary);
  }

  .about-hero {
    padding: 160px 0 100px;
    color: white;
    position: relative;
    overflow: hidden;
    background-color: var(--primary);
  }

  .hero-bg-text {
    position: absolute;
    top: 50%;
    left: 0;
    width: 100%;
    transform: translateY(-50%);
    pointer-events: none;
    opacity: 0.1;
    z-index: 0;
    white-space: nowrap;
    overflow: hidden;
  }

  .marquee-track {
    display: flex;
    width: max-content;
    animation: scroll-right-about 50s linear infinite; /* Left to Right */
  }

  .marquee-item {
    font-family: "Anton SC", sans-serif;
    font-size: 250px;
    line-height: 1;
    color: #fff;
    padding-right: 100px;
    text-transform: uppercase;
  }

  @keyframes scroll-right-about {
    0% {
      transform: translateX(-50%);
    }
    100% {
      transform: translateX(0);
    }
  }

  .container {
    max-width: 1440px;
    margin: 0 auto;
    padding: 0 80px;
  }

  .hero-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    position: relative;
    z-index: 1;
  }

  .hero-title {
    font-size: 80px;
    font-family: "Inter", sans-serif;
    font-weight: 900;
    line-height: 1;
    letter-spacing: -3px;
    margin-bottom: 40px;
    text-transform: uppercase;
  }

  .highlight {
    color: var(--orange);
  }

  .hero-description {
    font-size: 16px;
    color: rgba(255, 255, 255, 0.8);
    max-width: 509px;
    line-height: 1.6;
    margin-bottom: 40px;
    text-align: left;
  }

  .cta-button {
    background-color: var(--orange);
    color: white;
    padding: 16px 32px;
    border-radius: 9999px;
    display: inline-flex;
    align-items: center;
    gap: 12px;
    font-weight: 700;
    text-transform: uppercase;
    font-size: 14px;
    letter-spacing: 1px;
    transition: transform 0.3s ease;
  }

  .cta-button:hover {
    transform: translateY(-2px);
  }

  .hero-image-wrapper {
    position: relative;
    width: 613px;
    overflow: visible;
  }

  .hero-img {
    width: 100%;
    border-radius: 20px;
    object-fit: cover;
    box-shadow: 0 20px 50px rgba(0, 0, 0, 0.3);
  }

  .hero-asterisk {
    position: absolute;
    left: -70px;
    top: 50%;
    transform: translateY(-50%);
    width: 140px;
    z-index: 20;
    filter: drop-shadow(0 10px 20px rgba(0, 0, 0, 0.3));
  }

  /* Stats Section - Animated Marquee on Mobile */
  .stats-section {
    background-color: #ff5c1b;
    padding: 60px 0;
    color: white;
    width: 100%;
    overflow: hidden;
  }

  .stats-container {
    width: 100%;
  }

  .stats-marquee-track {
    display: flex;
    justify-content: space-between;
    width: 100%;
  }

  .stat-item {
    flex: 1;
    text-align: center;
    transition: all 0.4s ease;
    cursor: default;
    padding: 20px;
    min-width: 25%; /* Keeps 4 items on desktop */
  }

  .stat-item:hover {
    transform: scale(1.1) translateY(-10px);
  }

  .stat-value {
    font-size: 64px;
    font-weight: 900;
    font-family: "Inter", sans-serif;
    margin-bottom: 8px;
    color: #fff;
    text-shadow: 0 4px 10px rgba(0,0,0,0.1);
  }

  .stat-label {
    text-transform: uppercase;
    font-size: 14px;
    font-weight: 700;
    letter-spacing: 1px;
    color: rgba(255, 255, 255, 0.9);
  }

  @media (max-width: 768px) {
    .stats-marquee-track {
      width: max-content;
      animation: move-stats 25s linear infinite;
    }

    .stat-item {
      flex: 0 0 280px; /* Fixed width for carousel */
      min-width: auto;
    }

    .stat-value {
      font-size: 56px;
    }

    @keyframes move-stats {
      0% { transform: translateX(0); }
      100% { transform: translateX(-33.33%); } /* Exact offset for 3x duplication */
    }
  }


  /* Mission Section */
  .mission-section {
    background-color: white;
    padding: 80px 0;
  }

  .mission-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 60px;
  }

  .mission-text {
    flex: 1;
    max-width: 600px;
  }

  .mission-tag {
    color: var(--orange);
    text-transform: uppercase;
    font-weight: 700;
    letter-spacing: 1px;
    margin-bottom: 16px;
    display: block;
  }

  .mission-title {
    font-size: 44px;
    font-weight: 700;
    color: #0d0a2d;
    line-height: 1.1;
    margin-bottom: 24px;
    text-transform: uppercase;
  }

  .mission-description {
    font-size: 18px;
    color: #4b5563;
    line-height: 1.6;
    font-family: "Montserrat", sans-serif;
  }

  .mission-images {
    flex: 1.2;
    display: flex;
    gap: 20px;
    align-items: center;
    justify-content: flex-end;
  }

  .mission-img-1,
  .mission-img-2 {
    width: 48%;
    aspect-ratio: 1;
    border-radius: 20px;
    object-fit: cover;
    box-shadow: 0 20px 40px rgba(0,0,0,0.1);
    transition: var(--transition-smooth, all 0.4s ease);
  }

  .mission-img-2 {
    margin-top: 40px;
  }

  .mission-img-1:hover, .mission-img-2:hover {
    transform: translateY(-10px);
  }

  /* Values Section */
  /* Values Section */
  .values-section {
    background-color: white;
    padding: 100px 0;
  }

  .values-container {
    display: flex;
    flex-direction: column;
  }

  /* Values Section (Capabilities Style) */
  .values-section {
    background-color: #fff;
    padding: 60px 0 80px; /* Reduced vertical scale */
  }

  .values-header-top {
    margin-bottom: 40px;
    text-align: left;
  }

  .values-title {
    font-size: 44px;
    font-weight: 700;
    line-height: 1.1;
    letter-spacing: -1.5px;
    text-transform: uppercase;
    color: var(--primary);
  }

  .highlight {
    color: var(--orange);
  }
  
  .cap-content {
    display: flex;
    gap: 80px;
    align-items: flex-start;
  }
  
  .cap-left {
    flex: 1;
    position: relative;
    width: 100%;
  }
  
  .cap-main-img {
    width: 100%;
    height: auto;
    object-fit: contain;
  }
  
  .cap-tag {
    margin-top: 20px;
    font-size: 18px;
    text-transform: uppercase;
    color: var(--orange);
    font-weight: 700;
    letter-spacing: 1px;
  }
  
  .cap-right {
    flex: 1.2;
    display: flex;
    flex-direction: column;
  }
  
  .capability-item {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    padding: 24px;
    cursor: pointer;
    transition: all 0.3s ease;
    border-radius: 20px;
    margin-left: -24px;
  }
  
  .capability-item.active {
    background-color: #EFECFF;
  }
  
  .cap-info h3 {
    font-size: 28px;
    letter-spacing: -0.8px;
    margin-bottom: 0px;
    font-weight: 800;
    color: var(--primary);
    transition: margin 0.3s ease;
  }

  .capability-item.active .cap-info h3 {
    margin-bottom: 15px;
  }
  
  .cap-desc {
    display: grid;
    grid-template-rows: 0fr;
    transition: grid-template-rows 0.3s ease;
  }

  .capability-item.active .cap-desc {
    grid-template-rows: 1fr;
  }

  .cap-desc p {
    font-family: 'Poppins', sans-serif;
    font-size: 16px;
    opacity: 0.6;
    max-width: 460px;
    overflow: hidden;
    color: var(--primary);
    margin: 0;
  }

  .cap-arrow {
    width: 44px;
    height: 44px;
    border-radius: 50%;
    background: #f1f0ff;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--primary);
    transition: all 0.5s ease;
    flex-shrink: 0;
  }

  .capability-item.active .cap-arrow {
    background: var(--primary);
    color: white;
    transform: rotate(45deg);
  }

  .divider {
    height: 1px;
    background: rgba(0,0,0,0.05);
    width: 100%;
    margin: 10px 0;
  }

  .capability-item.active + .divider {
    opacity: 0;
  }

  /* Process Section */
  .process-section {
    background-color: #fff;
    padding: 120px 0;
    overflow: hidden;
  }

  .process-header {
    margin-bottom: 80px;
    text-align: left;
  }

  .process-tag {
    color: var(--orange);
    text-transform: uppercase;
    font-weight: 700;
    letter-spacing: 1px;
    margin-bottom: 16px;
    display: block;
  }

  .process-title {
    font-size: 80px;
    font-weight: 900;
    line-height: 1;
    letter-spacing: -3px;
    text-transform: uppercase;
    color: var(--primary);
  }

  .process-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 30px;
  }

  .process-card {
    position: relative;
    padding: 30px;
    background: #fbfbfc;
    border: 1px solid rgba(0,0,0,0.03);
    border-radius: 24px;
    transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
    cursor: default;
    z-index: 1;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    min-height: 320px;
  }

  .process-number {
    position: absolute;
    top: 10px;
    right: 20px; /* Moved to right for a smarter look */
    font-size: 140px;
    font-family: "Anton SC", sans-serif;
    font-weight: 900;
    color: var(--primary);
    opacity: 0.03;
    line-height: 1;
    z-index: -1;
    transition: all 0.5s ease;
  }

  .process-card:hover {
    transform: translateY(-10px) scale(1.01);
    background: white;
    box-shadow: 0 30px 60px rgba(41, 28, 108, 0.06);
    border-color: rgba(41, 28, 108, 0.08);
  }

  .process-card:hover .process-number {
    opacity: 0.1;
    color: var(--orange);
    transform: translateY(-5px);
  }

  .process-card-content h3 {
    font-size: 20px;
    font-weight: 800;
    color: var(--primary);
    text-transform: uppercase;
    margin-bottom: 12px;
    letter-spacing: -0.5px;
  }

  .process-card-content p {
    font-size: 14px;
    line-height: 1.5;
    color: rgba(10, 10, 10, 0.6);
    margin: 0;
  }

  .process-glow {
    position: absolute;
    bottom: -100px;
    right: -100px;
    width: 200px;
    height: 200px;
    background: var(--orange);
    filter: blur(100px);
    opacity: 0;
    transition: opacity 0.5s ease;
    border-radius: 50%;
    pointer-events: none;
  }

  .process-card:hover .process-glow {
    opacity: 0.2;
  }

  @media (max-width: 1024px) {
    .process-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 640px) {
    .process-grid {
      grid-template-columns: 1fr;
    }
    .process-title {
      font-size: 48px;
    }
  }

  /* Team Section */
  .team-section {
    background-color: #291c6c;
    padding: 80px 0;
    color: white;
  }

  .team-header {
    position: relative;
    text-align: left;
    margin-bottom: 60px;
  }

  .team-decoration {
    position: absolute;
    left: 45%;
    top: 50%;
    transform: translate(-50%, -50%);
    width: 82px;
  }

  .team-title-main {
    font-size: 80px;
    font-weight: 900;
    line-height: 1;
    letter-spacing: -4px;
    text-transform: uppercase;
  }

  .team-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 20px;
  }

  .team-member {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .member-image-box {
    width: 100%;
    aspect-ratio: 1;
    overflow: hidden;
    display: flex;
    align-items: flex-end;
    justify-content: center;
  }

  .member-img {
    height: 100%;
    width: 100%;
    object-fit: cover;
  }

  .member-info h3 {
    font-size: 16px;
    font-weight: 700;
    text-transform: uppercase;
    margin-bottom: 4px;
  }

  .member-info p {
    font-size: 14px;
    opacity: 0.6;
  }

  /* Responsive Refinements - 'Perfect' Mobile Fixes */
  @media (max-width: 1200px) {
    .container {
      padding: 0 40px;
    }
    .hero-title, .process-title, .team-title-main {
      font-size: 60px;
      letter-spacing: -2.5px;
    }
    .hero-container, .mission-container, .cap-content {
      flex-direction: column;
      gap: 60px;
      text-align: center;
    }
    .hero-description, .mission-description, .cap-desc p {
      margin: 0 auto 40px;
    }
    .hero-image-wrapper, .mission-images, .cap-left {
      width: 100%;
      max-width: 600px;
      margin: 0 auto;
    }
    .mission-images {
      justify-content: center;
    }
    .stat-value {
      font-size: 48px;
    }
  }

  @media (max-width: 768px) {
    .about-hero, .mission-section, .values-section, .process-section, .team-section {
      padding: 80px 0;
    }
    .hero-title, .process-title, .team-title-main {
      font-size: 40px;
      letter-spacing: -1.5px;
    }
    .stats-grid {
      display: flex; /* Horizontal Scroll */
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      gap: 0px;
      padding: 0 40px;
      margin-left: -40px;
      margin-right: -40px;
      scrollbar-width: none; /* Hide scrollbar Firefox */
    }
    .stats-grid::-webkit-scrollbar {
      display: none; /* Hide scrollbar Chrome/Safari */
    }
    .stat-item {
      flex: 0 0 280px; /* Fixed width for scrolling */
      scroll-snap-align: center;
      padding: 40px 20px;
    }
    .stat-value {
      font-size: 56px;
    }
    .capability-item {
      margin-left: 0;
      padding: 20px;
      text-align: left;
    }
    .cap-info h3 {
      font-size: 20px;
    }
    .process-grid, .team-grid {
      grid-template-columns: 1fr;
      gap: 32px;
    }
    .hero-asterisk {
      width: 80px;
      left: -20px;
    }
    .mission-title {
      font-size: 28px;
    }
  }

</style>
