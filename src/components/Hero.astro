---

---

<section class="hero">
  <div class="hero-bg-text">
    <div class="marquee-track">
      <div class="marquee-item">Ecommerce Partners — Ecommerce Partners — Ecommerce Partners — Ecommerce Partners —</div>
      <div class="marquee-item" aria-hidden="true">Ecommerce Partners — Ecommerce Partners — Ecommerce Partners — Ecommerce Partners —</div>
    </div>
  </div>
  
  <div class="container hero-container">
    <div class="hero-content">
      <h1 class="hero-title">
        ECOMMERCE SUCCESS<br />
        STARTS <span class="highlight">HERE</span>
      </h1>
      
      <div class="hero-bottom">
        <div class="description">
          <p>
            We help ambitious brands launch and scale high-converting online stores on Shopify, WooCommerce, Amazon, and beyond. From store setup to full-funnel growth strategies we turn traffic into revenue.
          </p>
          <a href="/contact" class="cta-btn">
            <span>Start Your Project</span>
            <div class="arrow">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
                <path d="M14.43 5.93L20.5 12l-6.07 6.07M3.5 12h16.83" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
          </a>
        </div>
      </div>
    </div>
    
    <div class="hero-image">
      <img src="/images/hero-main.png" alt="Ecommerce Success" class="main-img" />
      <img src="/images/asterisk.png" alt="" class="hero-asterisk" />
    </div>
  </div>
</section>

<style>
  .hero {
    background-color: var(--primary);
    min-height: 750px;
    height: 85vh;
    position: relative;
    overflow: hidden;
    color: #fff;
    display: flex;
    align-items: center;
    padding-bottom: 0;
  }
  
  .hero-bg-text {
    position: absolute;
    top: 50%;
    left: 0;
    width: 100%;
    transform: translateY(-50%);
    pointer-events: none;
    opacity: 0.1;
    z-index: 1;
    white-space: nowrap;
    overflow: hidden;
  }
  
  .marquee-track {
    display: flex;
    width: max-content;
    animation: scroll-left-hero 60s linear infinite;
  }
  
  .marquee-item {
    font-family: 'Anton SC', sans-serif;
    font-size: 200px;
    line-height: 1;
    color: #fff;
    padding-right: 50px;
    text-transform: uppercase;
  }
  
  @keyframes scroll-left-hero {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
  
  .hero-container {
    position: relative;
    z-index: 10;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 40px;
  }
  
  .hero-content {
    flex: 1.2;
    max-width: 700px;
  }
  
  .hero-title {
    font-family: 'Montserrat', sans-serif;
    font-size: 80px;
    font-weight: 800;
    line-height: 1;
    letter-spacing: -3px;
    text-transform: uppercase;
    margin-bottom: 40px;
  }
  
  .hero-title .highlight {
    color: var(--orange);
  }
  
  .hero-bottom {
    display: flex;
    justify-content: flex-start;
  }
  
  .description {
    max-width: 480px;
    display: flex;
    flex-direction: column;
    gap: 20px;
  }
  
  .description p {
    font-family: 'Geist', sans-serif;
    font-size: 15px;
    line-height: 1.6;
    color: #B3ACDB;
    text-transform: none;
    text-align: left;
  }
  
  .cta-btn {
    background-color: var(--orange);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 3.6px 15.3px;
    padding-right: 3.6px;
    border-radius: 36px;
    width: 209px;
    height: 50.5px;
    color: #fff;
    font-family: 'Poppins', sans-serif;
    font-weight: 500;
    font-size: 12.4px;
    text-transform: uppercase;
  }
  
  .arrow {
    background-color: var(--primary);
    width: 43px;
    height: 43px;
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
  }
  
  .hero-image {
    flex: 1;
    max-width: 600px;
    aspect-ratio: 1.5;
    border-radius: 28px;
    overflow: visible; /* Changed to visible to allow asterisk overlap */
    position: relative;
    z-index: 10;
  }
  
  .main-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    border-radius: 28px;
  }

  .hero-asterisk {
    position: absolute;
    left: -70px;
    top: 50%;
    transform: translateY(-50%);
    width: 160px;
    z-index: 20;
    filter: drop-shadow(0 10px 20px rgba(0,0,0,0.3));
  }

  @media (max-width: 1024px) {
    .hero-title {
      font-size: 80px;
    }
    .hero-image {
      width: 500px;
      height: 350px;
    }
  }

  @media (max-width: 768px) {
    .hero {
      height: auto;
      padding-top: 150px;
      padding-bottom: 50px;
    }
    .hero-title {
      font-size: 50px;
    }
    .hero-image {
      position: relative;
      top: 0;
      right: 0;
      width: 100%;
      height: 250px;
      margin-bottom: 30px;
    }
    .marquee-item {
      font-size: 100px;
    }
  }
</style>
