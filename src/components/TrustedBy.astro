    text: "http://localhost:3845/assets/8e64946529dd29d4579693bc1e4cef109cf036a4.svg",
    name: "Pollinate",
    markWidth: "22.87px",
    textWidth: "61.991px",
  },
];

// Duplicate for continuous loop
const marqueeLogos = [...logos, ...logos, ...logos, ...logos];
---

<section class="trusted">
  <div class="container trusted-container">
    <p class="trusted-title">Trusted By Companies</p>
    <div class="marquee-track">
      <div class="marquee-content">
        {
          marqueeLogos.map((logo) => (
            <div class="logo-pill">
              <div class="logo-content">
                <img
                  src={logo.mark}
                  alt=""
                  class="logo-mark"
                  style={`width: ${logo.markWidth}`}
                />
                <img
                  src={logo.text}
                  alt={logo.name}
                  class="logo-text"
                  style={`width: ${logo.textWidth}`}
                />
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </div>
</section>

<style>
  .trusted {
    background-color: #fff;
    padding: 80px 0;
    width: 100%;
    overflow: hidden;
  }

  .trusted-container {
    display: flex;
    flex-direction: column;
    align-items: flex-start; /* Align title to left */
    gap: 30px;
  }
  
  .trusted-title {
    font-size: 14px; /* More minimal */
    font-weight: 500;
    color: var(--primary);
    text-align: left;
    margin-bottom: 10px;
    opacity: 0.6;
    letter-spacing: 1px;
    text-transform: uppercase;
  }
  
  .marquee-track {
    width: 100%;
    overflow: hidden;
    position: relative;
    padding: 20px 0;
  }

  .marquee-content {
    display: flex !important;
    flex-direction: row !important; /* FORCE HORIZONTAL */
    flex-wrap: nowrap !important;
    align-items: center;
    gap: 60px; /* Increased gap for better spacing */
    width: max-content;
    animation: marquee-left-to-right 40s linear infinite;
  }

  @keyframes marquee-left-to-right {
    0% {
      transform: translateX(-50%);
    }
    100% {
      transform: translateX(0);
    }
  }

  .marquee-content:hover {
    animation-play-state: paused;
  }

  .logo-pill {
    display: flex !important;
    flex-direction: row !important;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    height: 40px; /* Slimmer pills */
    transition: transform 0.3s ease;
  }

  .logo-pill:hover {
    transform: scale(1.05);
  }

  .logo-content {
    display: flex !important;
    flex-direction: row !important;
    align-items: center;
    gap: 8px;
  }

  .logo-mark,
  .logo-text {
    height: 24.89px; /* Slightly smaller for premium look */
    display: block !important;
    object-fit: contain;
  }

  @media (max-width: 768px) {
    .trusted {
      padding: 50px 0;
    }
    .marquee-content {
      gap: 40px;
      animation-duration: 25s;
    }
    .logo-mark, .logo-text {
      height: 20px;
    }
  }
</style>


