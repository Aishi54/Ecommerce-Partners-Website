---
---
<section class="team">
  <div class="container">
    <div class="team-header">
      <div class="header-text">
        <h2 class="meet">MEET</h2>
        <h2 class="our-team">OUR TEAM</h2>
      </div>
      <div class="team-controls">
        <button class="team-prev" aria-label="Previous">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M19 12H5M5 12L12 19M5 12L12 5"/></svg>
        </button>
        <button class="team-next" aria-label="Next">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12H19M19 12L12 5M19 12L12 19"/></svg>
        </button>
      </div>
    </div>
    
    <div class="team-grid" id="team-grid">
      <div class="team-member">
        <div class="member-img">
          <img src="/images/t1.png" alt="Courtney Henry" class="team-img" />
        </div>
        <div class="member-info">
          <h3>Courtney Henry</h3>
          <p>Ecommerce Strategist</p>
        </div>
      </div>
      
      <div class="team-member">
        <div class="member-img">
          <img src="/images/t2.png" alt="Brooklyn Simmons" class="team-img" />
        </div>
        <div class="member-info">
          <h3>Brooklyn Simmons</h3>
          <p>Shopify Developer</p>
        </div>
      </div>
      
      <div class="team-member">
        <div class="member-img">
          <img src="/images/t3.png" alt="Bessie Cooper" class="team-img" />
        </div>
        <div class="member-info">
          <h3>Bessie Cooper</h3>
          <p>Marketplace Specialist</p>
        </div>
      </div>
      
      <div class="team-member">
        <div class="member-img">
          <img src="/images/t4.png" alt="Jeselyn Adona" class="team-img" />
        </div>
        <div class="member-info">
          <h3>JESELYN ADONA</h3>
          <p>Paid Ads Manager</p>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  const grid = document.getElementById('team-grid');
  const prevBtn = document.querySelector('.team-prev');
  const nextBtn = document.querySelector('.team-next');

  if (grid && prevBtn && nextBtn) {
    const scrollAmount = 300;
    
    prevBtn.addEventListener('click', () => {
      grid.scrollBy({ left: -scrollAmount, behavior: 'smooth' });
    });

    nextBtn.addEventListener('click', () => {
      grid.scrollBy({ left: scrollAmount, behavior: 'smooth' });
    });
  }
</script>

<style>
  .team {
    background-color: var(--primary);
    padding: 100px 0;
    color: #fff;
    min-height: auto;
  }
  
  .team-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    margin-bottom: 60px;
    gap: 32px;
  }
  
  .team-controls {
    display: none; /* Hide on desktop */
    gap: 16px;
    margin-bottom: 10px;
  }

  .team-controls button {
    width: 64px;
    height: 64px;
    border-radius: 50%;
    border: 1.5px solid rgba(255, 255, 255, 0.2);
    background: transparent;
    color: white;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
  }

  .team-controls button:hover {
    background-color: var(--orange);
    border-color: var(--orange);
    transform: scale(1.1);
  }

  .meet {
    font-size: 80px;
    font-weight: 700;
    line-height: 1;
    letter-spacing: -4px;
    text-transform: uppercase;
  }
  
  .our-team {
    font-size: 80px;
    font-weight: 700;
    line-height: 1;
    letter-spacing: -4px;
    color: var(--orange);
    text-transform: uppercase;
  }
  
  .team-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 32px;
    width: 100%;
    scrollbar-width: none;
  }

  .team-grid::-webkit-scrollbar {
    display: none;
  }
  
  .team-member {
    display: flex;
    flex-direction: column;
    gap: 20px;
    width: 100%;
    transition: all 0.5s cubic-bezier(0.22, 1, 0.36, 1);
    cursor: pointer;
    position: relative;
    padding: 10px;
    border-radius: 12px;
    scroll-snap-align: center;
  }
  
  .member-img {
    width: 100%;
    aspect-ratio: 1;
    background-color: rgba(255,255,255,0.05);
    position: relative;
    overflow: hidden;
    border-radius: 16px; /* Smoother on mobile */
  }
  
  .team-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(100%);
    transition: all 0.6s cubic-bezier(0.22, 1, 0.36, 1);
    opacity: 0.8;
  }

  .team-member:hover .team-img {
    filter: grayscale(0%);
    transform: scale(1.1);
    opacity: 1;
  }
  
  .member-info h3 {
    font-size: 20px;
    font-weight: 900;
    letter-spacing: -0.5px;
    text-transform: uppercase;
    color: white; /* Stronger contrast */
    margin-bottom: 4px;
  }

  .member-info p {
    font-size: 15px;
    opacity: 0.6;
    color: white;
  }

  @media (max-width: 1200px) {
    .container {
      padding: 0 40px;
    }
    .team-grid {
      grid-template-columns: 1fr 1fr;
    }
    .meet, .our-team {
      font-size: 60px;
    }
  }

  @media (max-width: 768px) {
    .team {
      padding: 60px 0 100px;
    }
    .team-header {
      flex-direction: column;
      align-items: flex-start;
      gap: 20px;
      margin-bottom: 40px;
    }
    .header-text {
      margin-bottom: 0;
    }
    .team-controls {
      display: flex;
      order: 2;
    }
    .team-grid {
      display: flex; /* Carousel row */
      overflow-x: auto;
      scroll-snap-type: x mandatory;
      margin: 0 -40px;
      padding: 0 40px;
      width: calc(100% + 80px);
      gap: 20px;
    }
    .team-member {
      flex: 0 0 100%; /* Show one card at a time */
      padding: 0;
    }
    .meet, .our-team {
      font-size: 48px;
      letter-spacing: -2px;
    }
    .member-info h3 {
      font-size: 18px;
      color: var(--orange); /* Match requested look */
    }
  }


</style>
